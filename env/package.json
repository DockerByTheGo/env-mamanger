{
  "name": "env",
  "type": "module",
  "private": true,
  "module": "index.ts",
  "scripts": {
    "lint": "bunx eslint src/Env.ts src/EnvManager.ts src/EnvManagerBuilder.ts tests/*.ts vitest.config.ts",
    "build": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun --bun vitest run",
