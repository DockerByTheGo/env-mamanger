  },
  "dependencies": {
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
